# App uses async SQLAlchemy; postgres:// / postgresql:// (no +driver) becomes +asyncpg.
FILIGRANE_ENV=development
FILIGRANE_LOG_LEVEL=info
FILIGRANE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/filigrane
# Railway injecte souvent DATABASE_URL ; l’app et Alembic s’en servent si
# FILIGRANE_DATABASE_URL est vide.
# SKIP_DB_MIGRATIONS=
FILIGRANE_ADMIN_TOKEN=
FILIGRANE_CORS_ORIGINS=http://127.0.0.1:3000
FILIGRANE_CHROME_EXTENSION_IDS=
FILIGRANE_OPENAPI_ENABLED=
FILIGRANE_RESEND_API_KEY=
# Must be an address on a domain verified in Resend (not example.com).
FILIGRANE_EMAIL_FROM=hello@your-verified-domain.tld
FILIGRANE_PUBLIC_APP_URL=http://127.0.0.1:3000
